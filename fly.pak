[ "$1" = install ] && FLY_HOME="$HOME" || FLY_HOME="/tmp/.fly.`id -u`/jkf";umask 077;mkdir -p "$FLY_HOME"
! chmod 700 "$FLY_HOME" && echo "Not owner of $FLY_HOME. Abort" >&2 && exit 1
type gtar >/dev/null 2>&1 && tar=gtar || tar=tar
exec 4<>"$FLY_HOME/.fly.lock";flock 4 2>/dev/null
export _fly_lock=1
rm -rf "$FLY_HOME/.fly.d";echo ""|base64 -d|$tar -xmpf - -C "$FLY_HOME" -J --no-same-owner
[[ "$1" = *sh ]] && _fly_destshell="$1" && shift
. "$FLY_HOME/.fly.d/fly" ${1:-loginshell}
