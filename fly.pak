[ "$1" = install ] && FLY_HOME="$HOME" || FLY_HOME="/tmp/.fly.`id -u`/jkf";umask 077;mkdir -p "$FLY_HOME";rm -rf "$FLY_HOME/.fly.d";! chmod 700 "$FLY_HOME" && echo "Not owner of $FLY_HOME. Abort" >&2 && exit 1;type gtar >/dev/null 2>&1 && tar=gtar || tar=tar; echo ""|base64 -d|$tar -xmjf - -C "$FLY_HOME" --no-same-owner
[[ "$1" = *sh ]] && _fly_destshell="$1" && shift
. "$FLY_HOME/.fly.d/fly" ${1:-loginshell}
